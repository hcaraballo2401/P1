# ==============================================================================
# CONFIGURACIÓN GENERAL
# ==============================================================================
APP_ENV=development
LOG_LEVEL=INFO

# ==============================================================================
# HUGGING FACE INFERENCE API
# Obtén tu token en: https://huggingface.co/settings/tokens
# Rol mínimo requerido:
# - Token clásico: "Read"
# - Token Fine-grained: permiso "Make calls to Inference Providers"
# ==============================================================================
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alternativa soportada por el backend (si prefieres nombre de docs oficiales):
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de clasificación de imágenes.
# Recomendado: microsoft/resnet-50 (rápido y estable para clasificación general)
# Alternativas:
#   - google/vit-base-patch16-224
#   - Modelos especializados en fauna silvestre (según disponibilidad en HF)
HF_MODEL_ID=microsoft/resnet-50
# URL completa opcional del endpoint de inferencia.
# Si se define, tiene prioridad sobre HF_MODEL_ID.
# Ejemplo:
# HF_API_URL=https://router.huggingface.co/hf-inference/models/microsoft/resnet-50

# Timeout en segundos para la petición a Hugging Face.
# Aumentar si el modelo está "cold" (primera petición puede tardar ~20s).
HF_TIMEOUT_SECONDS=30

# ==============================================================================
# VALIDACIÓN DE IMÁGENES
# ==============================================================================
# Tamaño máximo permitido por imagen (en bytes). Default: 10 MB.
MAX_IMAGE_SIZE_BYTES=10485760

# Tipos MIME aceptados (separados por coma, sin espacios).
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ==============================================================================
# LÓGICA DE IDENTIFICACIÓN
# ==============================================================================
# Umbral de confianza mínimo (0.0 - 1.0).
# Si la confianza del resultado principal es menor a este valor,
# el campo `requiere_revision_humana` será True en la respuesta.
CONFIDENCE_THRESHOLD=0.50

# Número máximo de candidatos alternativos a incluir en la respuesta.
MAX_ALTERNATIVES=3

# ==============================================================================
# YOUTUBE DATA API V3
# ==============================================================================
# Clave de API para buscar transmisiones en vivo de vida silvestre
YOUTUBE_API_KEY=AIzaSyBVROBKSDMdzGXE0NLF9iR56AzzEWz_jqI
